@{
    string id = ViewBag.id;
    string name = ViewBag.name;
    DateTime dt = ViewBag.value;
    bool fHasValue = dt.HasValue();
    string requiredAttr = ViewBag.fRequired ? "required" : string.Empty;
}
@if (Request.IsMobileDeviceOrTablet())
{
    <input type="date" name="@name" id="@id" @requiredAttr value="@(fHasValue ? dt.YMDString() : string.Empty)" />
}
else
{
    <input type="text" name="@name" id="@id" @requiredAttr autocomplete="off" pattern="^@RegexUtility.RegexPatternForShortDate$" value="@(fHasValue ? dt.ToShortDateString() : string.Empty)" placeholder="@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.ShortDatePattern" />
    <script>
        $(() => {
            $("#@id").datepicker({
                changeMonth: true,
                changeYear: true,
                showOtherMonths: true,
                selectOtherMonths: true,
                yearRange: "-90:+10",
                showButtonPanel: true,
                currentText: "@Html.Raw(Resources.LocalizedText.Today)",
                closeText: "@Resources.LocalizedText.Close",
                dateFormat: '@RegexUtility.ShortDatePatternToHtmlFormatString'
            });

            $.datepicker._gotoToday = function(id) {
                $(id).datepicker('setDate', new Date()).datepicker('hide').blur();
            };
        });
    </script>
}


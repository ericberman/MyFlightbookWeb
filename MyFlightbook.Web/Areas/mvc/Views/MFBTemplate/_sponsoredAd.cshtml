@using MyFlightbook.SponsoredAds
@using System.Globalization
@{
    SponsoredAd ad = ViewBag.sponsoredAd;
    ad.AddImpression();
}
<div style="padding: 0.5em; text-align: left;">
    <div class="c"><span class="fineprint">@Resources.LocalizedText.SponsoredAdHeader</span></div>
    <div style="display: flex; align-items: center;" class="w100">
        <div style="flex: auto;">
            @if (!String.IsNullOrEmpty(ad.PromoHeader))
            {
            <h3>@Branding.ReBrand(ad.PromoHeader)</h3>
            }
            <div>@Html.Raw(Branding.ReBrand(ad.PromoText ?? string.Empty).Linkify())</div>
        </div>
        <div style="flex: auto;">
            <a href="@String.Format(CultureInfo.InvariantCulture, "~/mvc/internal/AdTracker/{0}", ad.ID).ToAbsolute()" target="_blank"><img @(ad.PreferredHeight > 0 ? $"height={ad.PreferredHeight}px;" : string.Empty) @(ad.PreferredWidth > 0 ? $"width={ad.PreferredWidth}px" : string.Empty) src="@ad.ImagePath.ToAbsolute()" /></a>
        </div>
    </div>
</div>

